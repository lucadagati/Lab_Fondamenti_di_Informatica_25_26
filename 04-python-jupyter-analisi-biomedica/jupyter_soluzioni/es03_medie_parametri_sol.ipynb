      "source": [
        "n = -2\n",
        "while n <= 0:\n",
        "    # in notebook simuliamo una correzione manuale\n",
        "    n = 5\n",
        "\n",
        "i = 1\n",
        "while i <= n:\n",
        "    print(i)\n",
        "    i += 1\n",
        "print('n finale:', n)\n"
      ]
