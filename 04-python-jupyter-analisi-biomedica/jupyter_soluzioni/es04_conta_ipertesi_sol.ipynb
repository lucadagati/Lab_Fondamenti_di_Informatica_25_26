        "# Soluzione Esercizio 4 - Stringhe e vocali\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def conta_vocali(testo):\n",
        "    c = 0\n",
        "    for ch in testo.lower():\n",
        "        if ch in 'aeiou':\n",
        "            c += 1\n",
        "    return c\n",
        "\n",
        "frase = 'Programmare in Python e utile'\n",
        "print('Vocali:', conta_vocali(frase))\n"
      ]
    }
