      "outputs": [],
      "source": [
        "valori=[12,5,18,21,4,30,9]\n",
        "filtrati=[v for v in valori if v >= 10]\n",
        "quadrati=[v*v for v in filtrati]\n",
        "print('Filtrati:', filtrati)\n",
        "print('Quadrati:', quadrati)\n"
      ]
    }
