      "outputs": [],
      "source": [
        "testo='banana split'\n",
        "freq={}\n",
        "for ch in testo.lower():\n",
        "    if ch == ' ':\n",
        "        continue\n",
        "    if ch not in freq:\n",
        "        freq[ch]=0\n",
        "    freq[ch]+=1\n",
        "print(freq)\n"
      ]
    }
