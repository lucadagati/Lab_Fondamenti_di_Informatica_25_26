      "source": [
        "# Soluzione Esercizio 2 - Somma, media, massimo\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "numeri=[7,3,12,5,9,12,1]\n",
        "somma=0\n",
        "massimo=numeri[0]\n",
        "for n in numeri:\n",
        "    somma += n\n",
        "    if n > massimo:\n",
        "        massimo = n\n",
        "media = somma/len(numeri)\n",
        "print('Somma:', somma)\n",
        "print('Media:', round(media,2))\n",
        "print('Massimo:', massimo)\n"
      ]
    }
  ],
